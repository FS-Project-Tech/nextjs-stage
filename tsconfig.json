{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    // Performance optimizations
    "skipLibCheck": true, // Skip type checking in node_modules - major speed boost
    "strict": false,  // ⚠️ NOT RECOMMENDED - reduces type safety
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true, // Required for fast refresh
    "jsx": "react-jsx",
    
    // Incremental compilation - critical for speed
    "incremental": true,
    "tsBuildInfoFile": ".next/cache/tsconfig.tsbuildinfo",
    
    // Additional performance settings
    "assumeChangesOnlyAffectDirectDependencies": true, // Faster type checking
    
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  // "include": [
  //   "next-env.d.ts",
  //   "**/*.ts",
  //   "**/*.tsx",
  //   ".next/types/**/*.ts",
  //   ".next/dev/types/**/*.ts",
  //   "**/*.mts"
  // ],
  "include": [
  "next-env.d.ts",
  "next-auth.d.ts",
  "**/*.ts",
  "**/*.tsx",
  ".next/types/**/*.ts",
  ".next/dev/types/**/*.ts",
  "**/*.mts"
],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "build"
  ]
}
