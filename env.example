# ============================================
# WooCommerce API Credentials
# ============================================
# Get these from: WordPress Admin > WooCommerce > Settings > Advanced > REST API
# Create a new API key with Read/Write permissions

WC_API_URL=https://your-site.com/wp-json/wc/v3
WC_CONSUMER_KEY=ck_your_consumer_key_here
WC_CONSUMER_SECRET=cs_your_consumer_secret_here

# WooCommerce API Timeout (milliseconds)
# Default: 20000 (20 seconds)
# Increase for slower connections or complex queries
WOOCOMMERCE_API_TIMEOUT=20000

# ============================================
# App Configuration
# ============================================

# Site URL (used for SEO, sitemap, structured data)
# Production: https://yourdomain.com
# Development: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WordPress base URL (used for /brands page and WordPress REST API, e.g. product_brand taxonomy)
# If not set, the host from WC_API_URL is used. Required on Vercel: set this or ensure WC_API_URL is set.
# Example: https://your-wordpress.com (no trailing slash)
# NEXT_PUBLIC_WP_URL=https://your-site.com

# ============================================
# Optional: Redis Caching (RECOMMENDED for performance)
# ============================================
# Uncomment to enable Redis caching for better performance
# Format: redis://[username:password@]host:port[/db]
# Example: redis://localhost:6379
# Example with auth: redis://password@localhost:6379
REDIS_URL=redis://localhost:6379

# ============================================
# Optional: GraphQL (requires WPGraphQL + WooGraphQL plugins)
# ============================================
# Install WPGraphQL: https://www.wpgraphql.com/
# Install WooGraphQL: https://woographql.com/
# Then uncomment and set your GraphQL endpoint
# NEXT_PUBLIC_GRAPHQL_URL=https://your-site.com/graphql

# ============================================
# Optional: Tawk.to Live Chat
# ============================================
# Get Property ID and Widget ID from: Tawk.to Dashboard > Administration > Channels > Chat Widget > Direct Chat Link
# URL format: https://embed.tawk.to/PROPERTY_ID/WIDGET_ID
# NEXT_PUBLIC_TAWK_PROPERTY_ID=691a86c138a32d195703d11d
# NEXT_PUBLIC_TAWK_WIDGET_ID=your_widget_id_here

# ============================================
# Optional: Analytics & Tracking
# ============================================
# Google Analytics ID (if using)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Maps API key (for address autocomplete on checkout/address forms)
# Enable Places API and Maps JavaScript API in Google Cloud Console
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ============================================
# Optional: Feature Flags
# ============================================
# Enable/disable specific features
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_PWA=true

# ============================================
# Optional: Category Configuration
# ============================================
# Default category slug for homepage sections
# NEXT_PUBLIC_CONTINENCE_CATEGORY_SLUG=continence-care

# ============================================
# Server-Side Only Variables
# ============================================
# These are NOT exposed to the browser (no NEXT_PUBLIC_ prefix)
# Use for sensitive data like API keys, tokens, etc.

# JWT Secret (if using custom JWT implementation)
# JWT_SECRET=your-secret-key-here
# For "stay logged in" when the tab is closed, set WordPress JWT token expiry to 7 days or more
# (e.g. JWT Authentication for WP REST API: filter jwt_auth_expire to return 7 * DAY_IN_SECONDS)

# Database URL (if using database)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Email Configuration (if sending emails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@example.com

# ============================================
# Environment-Specific Settings
# ============================================
# NODE_ENV is automatically set by Next.js
# - development: npm run dev
# - production: npm run build && npm start
# - test: npm test

# ============================================
# Build Configuration
# ============================================
# Enable bundle analyzer
# ANALYZE=true
